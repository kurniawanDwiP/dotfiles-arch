(defalias
h (chord layer h)
a (chord layer a)
e (chord layer e)
r (chord layer r)
t (chord layer t)
s (chord layer s)
spc (chord layer spc)
)

(defchords layer $chord
(h) @modh
(a) @moda
(e) @mode
(r) @modr
(t) @modt
(s) @mods
(spc) @modspc
(h a  ) @fl
(  a e) @fr
(r t  ) @ml
(  t s) @mr
(r   s) @mu
(h   e) @md
(h a e) ret
(h spc) (layer-while-held symbol)
(a spc) (layer-while-held logical)
)

