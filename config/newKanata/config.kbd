(defcfg
process-unmapped-keys yes
concurrent-tap-hold yes
sequence-timeout 2000
rapid-event-delay 20
delegate-to-first-layer yes
danger-enable-cmd yes
log-layer-changes yes
)

(include layer.kbd)
(include template.kbd)
(include variable.kbd)
(include utility.kbd)
(include chord.kbd)

(defsrc
q   w   e   r   t   y   u   i   o   p   [  ]
a   s   d   f   g   h   j   k   l   ;   '
z   x   c   v   b   n   m   ,   .   /
caps
spc
)
