;;new chord
(defalias
clj (chord layer j)
clk (chord layer k)
cll (chord layer l)
cls (chord layer s)
cld (chord layer d)
clf (chord layer f)
clspc (chord layer spc)
)

(defchords layer $chord
(j) @rc
(k) @rs
(l) @ra
(s) @la
(d) @ls
(f) @lc
(spc) @spc
(j k  ) @fleft
(k l  ) @fright
(s d  ) @mleft
(  d f) @mright
(s   f) @mup
(j   l) @mdown
(j k l) ret
(j spc) @lSym
(k spc) @lLog
(l spc) @lNum
(f spc) (multi (cmd zsh -c "notify-send 'layer-mouse'") (layer-switch system))
)
