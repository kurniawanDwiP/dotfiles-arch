(deflayer base
tab   q     w     f     p     b     j     l     u     y     ;     [     ]
lrld  @a    @cls  @cld  @clf  g     m     @clj  @clk  @cll  @o   '
lsft  x     c     d     v     z     k     h     ,     .     /
                        @clspc
)

(deflayer symbol
tab   grv   [     ]     S-'   -     XX    XX    XX    XX    XX    XX    XX
lrld  S-[   S-9   S-0   S-]   /     left  down  up    right XX    XX
lsft  S-,   S-;   =     S-.   S-\   XX    XX    XX    XX    XX
                        @layer-switch
)

(deflayer logical
tab   S-1   S-\   S-/   S-7   XX    XX    XX    XX    XX    XX    XX    XX
lrld  S-6   S-5   S-2   S-4   XX    left  down  up    right XX    XX
lsft  XX    S-3   S-8   XX    XX    XX    XX    XX    XX    XX
                        @layer-switch
)

(deflayer system

tab   XX    @msu  XX    XX    XX    XX    vold  volu  XX    XX    XX    XX
lrld  @msl  @msd  @msr  XX    XX    @ml   @mwd  @mwu  @mr   XX    XX
lsft  XX    XX    XX    XX    XX    XX    XX    XX    XX    XX
                        @layer-switch
)

(deflayer numpad
tab   XX    S-5   S-6   XX    XX    XX    7     8     9     XX    XX    XX
lrld  S-=   -     S-8   /     XX    =     4     5     6     0     XX
lsft  XX    XX    XX    XX    XX    XX    1     2     3     XX
                        @layer-switch
)

(deflayer colemak
tab   q     w     f     p     b     j     l     u     y     ;     [     ]
lrld  a     r     s     t     g     m     n     e     i     o     '
lsft  x     c     d     v     z     k     h     ,     .     /
                        @spc
)

(deflayer nomods
tab   q     w     f     p     b     j     l     u     y     ;     [     ]
lrld  a     r     s     t     g     m     n     e     i     o     '
lsft  x     c     d     v     z     k     h     ,     .     /
                        @spc
)

(deflayer utility
tab   @work   @social   @media    XX      XX    XX    XX    XX    XX    XX     XX   XX
@col  @fleft  @mleft    @mright   @fright C-a   left  down  up    right XX     XX
lsft  XX      XX        XX        XX      XX    @notepad    C-n   XX    XX     XX
                        @spc
)

(deflayer blank
tab   XX    XX    XX    XX    XX    XX    XX    XX    XX    XX     XX     XX
lrld  XX    XX    XX    XX    XX    XX    XX    XX    XX    XX     XX
lsft  XX    XX    XX    XX    XX    XX    XX    XX    XX    XX
                        spc
)
